# Server
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/project_office?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-random
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Anthropic Claude — 화상회의 AI 회의록 자동 생성
# 키가 없으면 회의록은 'failed' 상태로 저장됨 (UI에서 사유 표시)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# 시스템 이메일 (초대 / 비밀번호 재설정 / 시스템 공지)
# 미설정 시 실제 발송 없이 로그만 기록 (개발 환경 안전)
SYSTEM_MAIL_SMTP_HOST=
SYSTEM_MAIL_SMTP_PORT=465
SYSTEM_MAIL_USER=
SYSTEM_MAIL_PASS=
SYSTEM_MAIL_FROM=Project Office <no-reply@ks-corporation.co.kr>
WEB_URL=http://localhost:5173

# 연차 자동 부여 스케줄러 비활성 (테스트/CI/다중 인스턴스 환경)
# DISABLE_VACATION_ACCRUAL_CRON=true
