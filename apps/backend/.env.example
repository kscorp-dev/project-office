# Server
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/project_office?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-random
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
