# Server
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/project_office?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-random
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Anthropic Claude — 화상회의 AI 회의록 자동 생성
# 키가 없으면 회의록은 'failed' 상태로 저장됨 (UI에서 사유 표시)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# 시스템 이메일 (초대 / 비밀번호 재설정 / 시스템 공지)
# 미설정 시 실제 발송 없이 로그만 기록 (개발 환경 안전)
SYSTEM_MAIL_SMTP_HOST=
SYSTEM_MAIL_SMTP_PORT=465
SYSTEM_MAIL_USER=
SYSTEM_MAIL_PASS=
SYSTEM_MAIL_FROM=Project Office <no-reply@ks-corporation.co.kr>
WEB_URL=http://localhost:5173

# 연차 자동 부여 스케줄러 비활성 (테스트/CI/다중 인스턴스 환경)
# DISABLE_VACATION_ACCRUAL_CRON=true

# Expo Push Notifications (FCM/APNs via Expo)
# 토큰 생성: https://expo.dev/accounts/<account>/settings/access-tokens
# 미설정이어도 동작하지만 rate limit이 엄격함
EXPO_ACCESS_TOKEN=
# 테스트/CI에서 푸시 발송 스킵
# DISABLE_PUSH=true

# CCTV 실시간 스트리밍 (RTSP → HLS)
# ffmpeg 바이너리 경로 (미설정 시 /api/cctv/cameras/:id/stream/start 가 501 반환)
CCTV_FFMPEG_PATH=
# PTZ 어댑터 기본값 (stub / onvif / hikvision 등) — 카메라별 개별 설정도 가능
CCTV_PTZ_DEFAULT_ADAPTER=stub
# ONVIF 표준 포트 (카메라마다 다를 수 있음, 일반적으로 80 또는 8000)
ONVIF_DEFAULT_PORT=80

# 캘린더 동기화 공개 피드 URL에 사용되는 기본 도메인
# 미설정 시 WEB_URL 또는 요청 host 사용
PUBLIC_BASE_URL=

# Google Calendar 양방향 동기화 (Phase 2)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# "승인된 리디렉션 URI"에 GOOGLE_OAUTH_REDIRECT_URI 등록 필요
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 기본값: ${PUBLIC_BASE_URL}/api/calendar-sync/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# AWS WorkMail 연동 (메일관리용)
# IAM 정책: workmail:*, ses:SendEmail 최소 권한 부여
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
WORKMAIL_ORGANIZATION_ID=

# IMAP/SMTP 메일박스 비밀번호 암호화 키 (32바이트 hex)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 프로덕션과 개발 환경은 반드시 서로 다른 값을 사용 (유출 시 기존 암호화본 전부 재암호화 필요)
MAIL_ENCRYPTION_KEY=

# 주차 이벤트 웹훅 shared secret (/api/parking/events/webhook 호출 시 X-Webhook-Secret 헤더 필수)
# AI detection 서비스와 백엔드 사이의 신뢰 경계 — 미설정 시 웹훅 엔드포인트 자동 비활성화
PARKING_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────────────────
# 보안 정책 (dev / prod 분리)
# ────────────────────────────────────────────────────────────────
# 1) 이 파일(.env.example)은 템플릿. 실제 값은 절대 커밋 금지 (.env).
# 2) production 배포 시:
#    - JWT_ACCESS_SECRET / JWT_REFRESH_SECRET 는 반드시 dev 와 다른 값 (32자 이상 랜덤)
#    - AWS_ACCESS_KEY_ID 는 production 전용 IAM 사용자로 발급
#    - MAIL_ENCRYPTION_KEY 는 Secrets Manager / HashiCorp Vault 등 외부 시크릿 저장소 사용 권장
# 3) 개발 중 AWS 키가 유출되었다고 판단되면:
#    AWS Console → IAM → Users → 해당 키 → "Make inactive" 후 새 키 발급
#    (실제 키 ID 가 .env.example 같은 공개 파일에 노출되면 그 자체로 rotate 대상)
