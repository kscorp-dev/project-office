generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 사용자 및 조직 =====

enum UserRole {
  super_admin
  admin
  dept_admin
  user
  guest
}

enum UserStatus {
  active
  inactive
  locked
  pending
}

model User {
  id             String     @id @default(uuid())
  employeeId     String     @unique @map("employee_id")
  email          String     @unique
  name           String
  password       String
  phone          String?
  role           UserRole   @default(user)
  status         UserStatus @default(pending)
  position       String?
  profileImage   String?    @map("profile_image")
  departmentId   String?    @map("department_id")
  lastLoginAt    DateTime?  @map("last_login_at")
  loginFailCount Int        @default(0) @map("login_fail_count")
  lockedUntil    DateTime?  @map("locked_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  department      Department?      @relation(fields: [departmentId], references: [id])
  devices         UserDevice[]
  passwordHistory PasswordHistory[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]

  // 부서 관리자 역참조
  managedDepartments Department[] @relation("DepartmentManager")

  // 전자결재
  draftedDocuments    ApprovalDocument[]   @relation("DraftedDocuments")
  approvalLines       ApprovalLine[]       @relation("ApprovalLines")
  approvalReferences  ApprovalReference[]  @relation("ApprovalReferences")
  delegationsFrom     ApprovalDelegation[] @relation("DelegationsFrom")
  delegationsTo       ApprovalDelegation[] @relation("DelegationsTo")

  // 메신저
  createdRooms        ChatRoom[]           @relation("CreatedRooms")
  chatParticipants    ChatParticipant[]    @relation("ChatParticipants")
  sentMessages        Message[]            @relation("SentMessages")
  messageReads        MessageRead[]        @relation("MessageReads")
  messageMentions     MessageMention[]     @relation("MessageMentions")

  // 근태
  attendances         Attendance[]         @relation("Attendances")
  vacations           Vacation[]           @relation("Vacations")
  vacationBalances    VacationBalance[]    @relation("VacationBalances")

  // 캘린더
  calendarEvents      CalendarEvent[]      @relation("CalendarEvents")
  eventAttendees      EventAttendee[]      @relation("EventAttendees")

  // 게시판
  authoredPosts       Post[]               @relation("AuthoredPosts")
  authoredComments    Comment[]            @relation("AuthoredComments")
  postReads           PostRead[]           @relation("PostReads")

  // 작업지시서
  createdTaskOrders    TaskOrder[]          @relation("CreatedTaskOrders")
  taskAssignees        TaskAssignee[]       @relation("TaskAssignees")
  taskStatusChanges    TaskStatusHistory[]  @relation("TaskStatusChanges")
  taskComments         TaskComment[]        @relation("TaskComments")
  uploadedDesignFiles  TaskDesignFile[]     @relation("UploadedDesignFiles")
  taskFileLogs         TaskFileLog[]        @relation("TaskFileLogs")

  // 자재관리
  inventoryProcessed   InventoryTransaction[] @relation("InventoryProcessed")

  // 화상회의
  hostedMeetings       Meeting[]              @relation("HostedMeetings")
  meetingParticipants  MeetingParticipant[]   @relation("MeetingParticipants")

  // 문서관리
  ownedFolders         DocumentFolder[]       @relation("OwnedFolders")
  uploadedDocuments    Document[]             @relation("UploadedDocuments")

  @@index([departmentId])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Department {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  parentId  String? @map("parent_id")
  managerId String? @map("manager_id")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  depth     Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  manager  User?        @relation("DepartmentManager", fields: [managerId], references: [id])
  users    User[]

  @@index([parentId])
  @@index([code])
  @@map("departments")
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  deviceId   String   @map("device_id")
  deviceType String   @map("device_type") // web, ios, android
  deviceName String   @map("device_name")
  pushToken  String?  @map("push_token")
  isActive   Boolean  @default(true) @map("is_active")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("user_devices")
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_history")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  family    String   // Token family for rotation detection
  deviceId  String?  @map("device_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

// ===== 전자결재 =====

enum ApprovalDocStatus {
  draft
  pending
  approved
  rejected
  withdrawn
}

enum ApprovalLineStatus {
  pending
  approved
  rejected
  skipped
}

enum ApprovalLineType {
  serial
  parallel
}

model ApprovalTemplate {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  category    String  // 기안, 지출, 휴가, 출장, 구매, 보고, 회의록, 자유양식
  description String?
  formSchema  Json?   @map("form_schema") // 양식 필드 정의
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  documents ApprovalDocument[]

  @@map("approval_templates")
}

model ApprovalDocument {
  id             String            @id @default(uuid())
  docNumber      String            @unique @map("doc_number") // {양식코드}-{연도}-{순번}
  templateId     String            @map("template_id")
  title          String
  content        String            // HTML 본문
  formData       Json?             @map("form_data") // 양식 데이터
  status         ApprovalDocStatus @default(draft)
  drafterId      String            @map("drafter_id")
  currentStep    Int               @default(0) @map("current_step")
  urgency        String            @default("normal") // normal, urgent
  submittedAt    DateTime?         @map("submitted_at")
  completedAt    DateTime?         @map("completed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  template    ApprovalTemplate   @relation(fields: [templateId], references: [id])
  drafter     User               @relation("DraftedDocuments", fields: [drafterId], references: [id])
  lines       ApprovalLine[]
  attachments ApprovalAttachment[]
  references  ApprovalReference[]

  @@index([drafterId])
  @@index([status])
  @@index([templateId])
  @@index([createdAt])
  @@map("approval_documents")
}

model ApprovalLine {
  id         String             @id @default(uuid())
  documentId String             @map("document_id")
  approverId String             @map("approver_id")
  step       Int                // 결재 순서
  type       ApprovalLineType   @default(serial)
  status     ApprovalLineStatus @default(pending)
  comment    String?
  actedAt    DateTime?          @map("acted_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approver User             @relation("ApprovalLines", fields: [approverId], references: [id])

  @@index([documentId])
  @@index([approverId])
  @@index([status])
  @@map("approval_lines")
}

model ApprovalAttachment {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("approval_attachments")
}

model ApprovalReference {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User             @relation("ApprovalReferences", fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@index([userId])
  @@map("approval_references")
}

model ApprovalDelegation {
  id          String    @id @default(uuid())
  fromUserId  String    @map("from_user_id")
  toUserId    String    @map("to_user_id")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  reason      String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  fromUser User @relation("DelegationsFrom", fields: [fromUserId], references: [id])
  toUser   User @relation("DelegationsTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@map("approval_delegations")
}

// ===== 메신저 =====

enum MessageType {
  text
  image
  file
  system
}

model ChatRoom {
  id        String   @id @default(uuid())
  name      String?
  type      String   @default("direct") // direct, group
  creatorId String?  @map("creator_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator      User?             @relation("CreatedRooms", fields: [creatorId], references: [id])
  participants ChatParticipant[]
  messages     Message[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id            String    @id @default(uuid())
  roomId        String    @map("room_id")
  userId        String    @map("user_id")
  lastReadAt    DateTime  @default(now()) @map("last_read_at")
  isNotifyOn    Boolean   @default(true) @map("is_notify_on")
  joinedAt      DateTime  @default(now()) @map("joined_at")
  leftAt        DateTime? @map("left_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation("ChatParticipants", fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id        String      @id @default(uuid())
  roomId    String      @map("room_id")
  senderId  String?     @map("sender_id")
  type      MessageType @default(text)
  content   String
  metadata  Json?       // 파일정보, 이미지 사이즈 등
  parentId  String?     @map("parent_id") // 답장
  isEdited  Boolean     @default(false) @map("is_edited")
  isDeleted Boolean     @default(false) @map("is_deleted")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  room    ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender  User?        @relation("SentMessages", fields: [senderId], references: [id])
  parent  Message?     @relation("MessageReplies", fields: [parentId], references: [id])
  replies Message[]    @relation("MessageReplies")
  reads   MessageRead[]
  mentions MessageMention[]

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageReads", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model MessageMention {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageMentions", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_mentions")
}

// ===== CCTV =====

model Camera {
  id          String  @id @default(uuid())
  name        String
  rtspUrl     String  @map("rtsp_url")
  location    String?
  groupId     String? @map("group_id")
  isActive    Boolean @default(true) @map("is_active")
  isPtz       Boolean @default(false) @map("is_ptz")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group      CameraGroup? @relation(fields: [groupId], references: [id])
  recordings Recording[]

  @@index([groupId])
  @@map("cameras")
}

model CameraGroup {
  id        String   @id @default(uuid())
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  cameras Camera[]

  @@map("camera_groups")
}

model Recording {
  id        String   @id @default(uuid())
  cameraId  String   @map("camera_id")
  filePath  String   @map("file_path")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  fileSize  BigInt   @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId, startTime])
  @@map("recordings")
}

// ===== 근태관리 =====

enum AttendanceType {
  check_in
  check_out
}

enum VacationType {
  annual        // 연차
  half_am       // 오전 반차
  half_pm       // 오후 반차
  sick          // 병가
  special       // 특별휴가
  compensatory  // 대체휴가
}

enum VacationStatus {
  pending
  approved
  rejected
  cancelled
}

model Attendance {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  type         AttendanceType
  checkTime    DateTime       @map("check_time")
  latitude     Float?
  longitude    Float?
  ipAddress    String?        @map("ip_address")
  deviceType   String?        @map("device_type")
  note         String?
  createdAt    DateTime       @default(now()) @map("created_at")

  user User @relation("Attendances", fields: [userId], references: [id])

  @@index([userId, checkTime])
  @@map("attendances")
}

model WorkSchedule {
  id        String @id @default(uuid())
  name      String
  startTime String @map("start_time") // "09:00"
  endTime   String @map("end_time")   // "18:00"
  isDefault Boolean @default(false) @map("is_default")

  @@map("work_schedules")
}

model Vacation {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  type             VacationType
  startDate        DateTime       @map("start_date")
  endDate          DateTime       @map("end_date")
  days             Float          // 0.5 for half-day
  reason           String?
  status           VacationStatus @default(pending)
  approvalDocId    String?        @map("approval_doc_id")
  approvedBy       String?        @map("approved_by")
  approvedAt       DateTime?      @map("approved_at")
  rejectionReason  String?        @map("rejection_reason")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user User @relation("Vacations", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("vacations")
}

model VacationBalance {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  year        Int
  totalDays   Float  @default(15) @map("total_days")
  usedDays    Float  @default(0)  @map("used_days")
  remainDays  Float  @default(15) @map("remain_days")

  user User @relation("VacationBalances", fields: [userId], references: [id])

  @@unique([userId, year])
  @@map("vacation_balances")
}

// ===== 캘린더 =====

enum EventRepeat {
  none
  daily
  weekly
  monthly
  yearly
}

model CalendarEvent {
  id          String      @id @default(uuid())
  title       String
  description String?
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  allDay      Boolean     @default(false) @map("all_day")
  location    String?
  color       String?     @default("#3b82f6")
  repeat      EventRepeat @default(none)
  scope       String      @default("personal") // personal, department, company
  creatorId   String      @map("creator_id")
  departmentId String?    @map("department_id")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  creator     User            @relation("CalendarEvents", fields: [creatorId], references: [id])
  attendees   EventAttendee[]

  @@index([creatorId])
  @@index([startDate, endDate])
  @@index([scope])
  @@map("calendar_events")
}

model EventAttendee {
  id       String @id @default(uuid())
  eventId  String @map("event_id")
  userId   String @map("user_id")
  status   String @default("pending") // pending, accepted, declined

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("EventAttendees", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ===== 게시판 =====

model Board {
  id          String  @id @default(uuid())
  name        String
  type        String  @default("general") // notice, general, department
  description String?
  departmentId String? @map("department_id")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  posts Post[]

  @@map("boards")
}

model Post {
  id         String   @id @default(uuid())
  boardId    String   @map("board_id")
  authorId   String   @map("author_id")
  title      String
  content    String   // HTML
  isPinned   Boolean  @default(false) @map("is_pinned")
  isMustRead Boolean  @default(false) @map("is_must_read")
  viewCount  Int      @default(0) @map("view_count")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  board       Board         @relation(fields: [boardId], references: [id])
  author      User          @relation("AuthoredPosts", fields: [authorId], references: [id])
  comments    Comment[]
  reads       PostRead[]
  attachments PostAttachment[]

  @@index([boardId, createdAt])
  @@index([authorId])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User      @relation("AuthoredComments", fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
  @@map("comments")
}

model PostRead {
  id     String   @id @default(uuid())
  postId String   @map("post_id")
  userId String   @map("user_id")
  readAt DateTime @default(now()) @map("read_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReads", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_reads")
}

model PostAttachment {
  id       String   @id @default(uuid())
  postId   String   @map("post_id")
  fileName String   @map("file_name")
  filePath String   @map("file_path")
  fileSize Int      @map("file_size")
  mimeType String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

// ===== 작업지시서 =====

enum TaskOrderStatus {
  draft
  instructed
  in_progress
  partial_complete
  work_complete
  billing_complete
  final_complete
  discarded
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum BillingType {
  tax_invoice
  cash_receipt
  other
}

enum BillingStatus {
  pending
  billed
  paid
}

enum FileLogAction {
  upload
  download
  view
  approve
  reject
}

model Client {
  id              String  @id @default(uuid())
  companyName     String  @map("company_name")
  businessNumber  String? @map("business_number")
  representative  String?
  contactPerson   String? @map("contact_person")
  phone           String?
  email           String?
  address         String?
  note            String?
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  taskOrders     TaskOrder[]
  supplierItems  InventoryItem[] @relation("SupplierItems")

  @@map("clients")
}

model TaskOrder {
  id                  String          @id @default(uuid())
  taskNumber          String          @unique @map("task_number")
  title               String
  description         String?
  creatorId           String          @map("creator_id")
  priority            TaskPriority    @default(normal)
  status              TaskOrderStatus @default(draft)
  category            String?
  instructionDate     DateTime?       @map("instruction_date")
  dueDate             DateTime?       @map("due_date")
  completedAt         DateTime?       @map("completed_at")
  clientId            String?         @map("client_id")
  deliveryAddress     Json?           @map("delivery_address")
  additionalNote      String?         @map("additional_note")
  approvalDocumentId  String?         @map("approval_document_id")
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  creator       User                @relation("CreatedTaskOrders", fields: [creatorId], references: [id])
  client        Client?             @relation(fields: [clientId], references: [id])
  assignees     TaskAssignee[]
  items         TaskItem[]
  billing       TaskBilling?
  statusHistory TaskStatusHistory[]
  checklist     TaskChecklist[]
  comments      TaskComment[]
  designFiles   TaskDesignFile[]
  fileLogs      TaskFileLog[]

  @@index([creatorId])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@map("task_orders")
}

model TaskAssignee {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  userId String @map("user_id")
  role   String @default("main") // main, support, reviewer, designer
  status String @default("pending") // pending, accepted, completed

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskAssignees", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model TaskItem {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  itemName    String   @map("item_name")
  description String?
  quantity    Float    @default(1)
  unit        String?
  unitPrice   Float?   @map("unit_price")
  totalPrice  Float?   @map("total_price")
  sortOrder   Int      @default(0) @map("sort_order")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_items")
}

model TaskBilling {
  id               String        @id @default(uuid())
  taskId           String        @unique @map("task_id")
  billingRequired  Boolean       @default(true) @map("billing_required")
  billingType      BillingType?  @map("billing_type")
  amount           Float?
  vatIncluded      Boolean       @default(true) @map("vat_included")
  noBillingReason  String?       @map("no_billing_reason")
  billingStatus    BillingStatus @default(pending) @map("billing_status")
  billedAt         DateTime?     @map("billed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_billings")
}

model TaskStatusHistory {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String   @map("changed_by")
  comment    String?
  changedAt  DateTime @default(now()) @map("changed_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskStatusChanges", fields: [changedBy], references: [id])

  @@index([taskId])
  @@map("task_status_history")
}

model TaskChecklist {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  content     String
  isCompleted Boolean  @default(false) @map("is_completed")
  completedBy String?  @map("completed_by")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklists")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskComments", fields: [userId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model TaskDesignFile {
  id             String    @id @default(uuid())
  taskId         String    @map("task_id")
  fileName       String    @map("file_name")
  filePath       String    @map("file_path")
  fileSize       BigInt    @map("file_size")
  fileType       String    @map("file_type") // ai, psd, pdf, eps, svg
  mimeType       String    @map("mime_type")
  version        Int       @default(1)
  thumbnailPath  String?   @map("thumbnail_path")
  uploadedBy     String    @map("uploaded_by")
  isApproved     Boolean   @default(false) @map("is_approved")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  approveComment String?   @map("approve_comment")
  isLatest       Boolean   @default(true) @map("is_latest")
  parentFileId   String?   @map("parent_file_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  task       TaskOrder       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader   User            @relation("UploadedDesignFiles", fields: [uploadedBy], references: [id])
  parentFile TaskDesignFile?  @relation("DesignFileVersions", fields: [parentFileId], references: [id])
  versions   TaskDesignFile[] @relation("DesignFileVersions")
  logs       TaskFileLog[]

  @@index([taskId])
  @@index([uploadedBy])
  @@map("task_design_files")
}

model TaskFileLog {
  id          String        @id @default(uuid())
  taskId      String        @map("task_id")
  fileId      String        @map("file_id")
  userId      String        @map("user_id")
  action      FileLogAction
  ipAddress   String?       @map("ip_address")
  deviceType  String?       @map("device_type")
  deviceInfo  String?       @map("device_info")
  fileVersion Int           @map("file_version")
  comment     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  task TaskOrder      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file TaskDesignFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User           @relation("TaskFileLogs", fields: [userId], references: [id])

  @@index([taskId])
  @@index([fileId])
  @@index([userId])
  @@map("task_file_logs")
}

model DeliveryPreset {
  id            String  @id @default(uuid())
  name          String
  companyName   String? @map("company_name")
  contactPerson String? @map("contact_person")
  phone         String?
  address       String?
  isDefault     Boolean @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("delivery_presets")
}

// ===== 자재관리 =====

enum InventoryTxType {
  in_stock     // 입고
  out_stock    // 출고
  return_stock // 반품
  adjust       // 재고 조정
}

model InventoryCategory {
  id        String  @id @default(uuid())
  name      String
  parentId  String? @map("parent_id")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  parent   InventoryCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children InventoryCategory[] @relation("CategoryTree")
  items    InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id            String  @id @default(uuid())
  code          String  @unique // 자재코드
  name          String
  categoryId    String? @map("category_id")
  unit          String  @default("EA") // EA, BOX, SET, KG, M 등
  specification String? // 규격
  description   String?
  minStock      Int     @default(0) @map("min_stock")
  currentStock  Int     @default(0) @map("current_stock")
  unitPrice     Float?  @map("unit_price")
  location      String? // 보관위치
  supplierId    String? @map("supplier_id")
  imageUrl      String? @map("image_url")
  isActive      Boolean @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category     InventoryCategory? @relation(fields: [categoryId], references: [id])
  supplier     Client?            @relation("SupplierItems", fields: [supplierId], references: [id])
  transactions InventoryTransaction[]

  @@index([categoryId])
  @@index([code])
  @@map("inventory_items")
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  itemId      String          @map("item_id")
  type        InventoryTxType
  quantity    Int
  unitPrice   Float?          @map("unit_price")
  totalPrice  Float?          @map("total_price")
  beforeStock Int             @map("before_stock")
  afterStock  Int             @map("after_stock")
  reason      String?
  reference   String?         // 관련 문서번호 (작업지시서 등)
  processedBy String          @map("processed_by")
  processedAt DateTime        @default(now()) @map("processed_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  item      InventoryItem @relation(fields: [itemId], references: [id])
  processor User          @relation("InventoryProcessed", fields: [processedBy], references: [id])

  @@index([itemId])
  @@index([type])
  @@index([processedAt])
  @@map("inventory_transactions")
}

// ===== 화상회의 =====

enum MeetingStatus {
  scheduled
  in_progress
  ended
  cancelled
}

model Meeting {
  id           String        @id @default(uuid())
  title        String
  description  String?
  hostId       String        @map("host_id")
  status       MeetingStatus @default(scheduled)
  roomCode     String        @unique @map("room_code")
  scheduledAt  DateTime?     @map("scheduled_at")
  startedAt    DateTime?     @map("started_at")
  endedAt      DateTime?     @map("ended_at")
  maxParticipants Int        @default(16) @map("max_participants")
  isRecording  Boolean       @default(false) @map("is_recording")
  password     String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  host         User               @relation("HostedMeetings", fields: [hostId], references: [id])
  participants MeetingParticipant[]

  @@index([hostId])
  @@index([scheduledAt])
  @@index([status])
  @@map("meetings")
}

model MeetingParticipant {
  id        String    @id @default(uuid())
  meetingId String    @map("meeting_id")
  userId    String    @map("user_id")
  role      String    @default("participant") // host, participant
  joinedAt  DateTime? @map("joined_at")
  leftAt    DateTime? @map("left_at")
  isInvited Boolean   @default(true) @map("is_invited")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation("MeetingParticipants", fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

// ===== 문서관리 =====

model DocumentFolder {
  id        String  @id @default(uuid())
  name      String
  parentId  String? @map("parent_id")
  ownerId   String  @map("owner_id")
  isShared  Boolean @default(false) @map("is_shared")
  sortOrder Int     @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  owner     User             @relation("OwnedFolders", fields: [ownerId], references: [id])
  documents Document[]

  @@index([ownerId])
  @@index([parentId])
  @@map("document_folders")
}

model Document {
  id          String   @id @default(uuid())
  folderId    String?  @map("folder_id")
  uploaderId  String   @map("uploader_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    BigInt   @map("file_size")
  mimeType    String   @map("mime_type")
  version     Int      @default(1)
  description String?
  tags        String[] @default([])
  isShared    Boolean  @default(false) @map("is_shared")
  isActive    Boolean  @default(true) @map("is_active")
  downloadCount Int    @default(0) @map("download_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  folder   DocumentFolder? @relation(fields: [folderId], references: [id])
  uploader User            @relation("UploadedDocuments", fields: [uploaderId], references: [id])

  @@index([folderId])
  @@index([uploaderId])
  @@map("documents")
}

// ===== 관리콘솔 (SystemSetting) =====

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general") // general, security, notification, system
  description String?
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ===== 기능 모듈 관리 =====

model FeatureModule {
  id          String  @id @default(uuid())
  name        String  @unique
  displayName String  @map("display_name")
  description String?
  isEnabled   Boolean @default(true) @map("is_enabled")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_modules")
}

// ===== 감사 로그 =====

enum AuditAction {
  login
  logout
  login_failed
  token_refresh
  password_change
  user_create
  user_update
  user_delete
  role_change
  department_create
  department_update
  department_delete
  module_toggle
  settings_change
  approval_submit
  approval_approve
  approval_reject
  approval_withdraw
}

enum RiskLevel {
  low
  medium
  high
  critical
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String?     @map("user_id")
  action       AuditAction
  resourceType String?     @map("resource_type")
  resourceId   String?     @map("resource_id")
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  deviceId     String?     @map("device_id")
  details      Json?
  result       String      @default("success") // success, failure
  riskLevel    RiskLevel   @default(low) @map("risk_level")
  createdAt    DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([riskLevel])
  @@map("audit_logs")
}


// ===== 주차 추적 =====

enum ParkingEventType {
  entry
  exit
}

model ParkingZone {
  id         String   @id @default(uuid())
  name       String                         // e.g. "A구역"
  label      String                         // e.g. "A"
  x1         Float                          // normalized 0-1
  y1         Float
  x2         Float
  y2         Float
  totalSpots Int      @default(0) @map("total_spots")
  cameraId   String?  @map("camera_id")     // detection 서버 카메라 ID
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lines  ParkingLine[]
  events ParkingEvent[]

  @@map("parking_zones")
}

model ParkingLine {
  id        String   @id @default(uuid())
  zoneId    String   @map("zone_id")
  name      String                           // e.g. "입구 라인"
  type      String                           // "entry" | "exit" | "both"
  x1        Float                            // normalized 0-1
  y1        Float
  x2        Float
  y2        Float
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  zone ParkingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("parking_lines")
}

model ParkingEvent {
  id          String           @id @default(uuid())
  zoneId      String?          @map("zone_id")
  type        ParkingEventType
  plateNumber String?          @map("plate_number")  // 4자리
  trackId     Int?             @map("track_id")
  cameraId    String?          @map("camera_id")
  lineId      String?          @map("line_id")
  direction   String?                                  // "up", "down", "left", "right"
  createdAt   DateTime         @default(now()) @map("created_at")

  zone ParkingZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([type])
  @@index([plateNumber])
  @@index([zoneId])
  @@map("parking_events")
}
