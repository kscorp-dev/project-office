generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 사용자 및 조직 =====

enum UserRole {
  super_admin
  admin
  dept_admin
  user
  guest
}

enum UserStatus {
  active
  inactive
  locked
  pending
}

model User {
  id             String     @id @default(uuid())
  employeeId     String     @unique @map("employee_id")
  email          String     @unique
  name           String
  password       String
  phone          String?
  role           UserRole   @default(user)
  status         UserStatus @default(pending)
  position       String?
  profileImage   String?    @map("profile_image")
  departmentId   String?    @map("department_id")
  lastLoginAt    DateTime?  @map("last_login_at")
  loginFailCount Int        @default(0) @map("login_fail_count")
  lockedUntil    DateTime?  @map("locked_until")
  /// 입사일 (연차 자동 부여 계산 기준 — 근로기준법 근속년수)
  hireDate       DateTime?  @db.Date @map("hire_date")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  department      Department?      @relation(fields: [departmentId], references: [id])
  devices         UserDevice[]
  passwordHistory PasswordHistory[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]

  // 부서 관리자 역참조
  managedDepartments Department[] @relation("DepartmentManager")

  // 전자결재
  draftedDocuments    ApprovalDocument[]   @relation("DraftedDocuments")
  approvalLines       ApprovalLine[]       @relation("ApprovalLines")
  approvalReferences  ApprovalReference[]  @relation("ApprovalReferences")
  delegationsFrom     ApprovalDelegation[] @relation("DelegationsFrom")
  delegationsTo       ApprovalDelegation[] @relation("DelegationsTo")

  // 메신저
  createdRooms        ChatRoom[]           @relation("CreatedRooms")
  chatParticipants    ChatParticipant[]    @relation("ChatParticipants")
  sentMessages        Message[]            @relation("SentMessages")
  messageReads        MessageRead[]        @relation("MessageReads")
  messageMentions     MessageMention[]     @relation("MessageMentions")

  // 근태
  attendances         Attendance[]         @relation("Attendances")
  vacations           Vacation[]           @relation("Vacations")
  vacationBalances    VacationBalance[]    @relation("VacationBalances")

  // 캘린더
  calendarEvents      CalendarEvent[]      @relation("CalendarEvents")
  eventAttendees      EventAttendee[]      @relation("EventAttendees")
  calendarCategories  CalendarCategory[]   @relation("OwnedCalendarCategories")

  // 게시판
  authoredPosts       Post[]               @relation("AuthoredPosts")
  authoredComments    Comment[]            @relation("AuthoredComments")
  postReads           PostRead[]           @relation("PostReads")

  // 작업지시서
  createdTaskOrders    TaskOrder[]          @relation("CreatedTaskOrders")
  taskAssignees        TaskAssignee[]       @relation("TaskAssignees")
  taskStatusChanges    TaskStatusHistory[]  @relation("TaskStatusChanges")
  taskComments         TaskComment[]        @relation("TaskComments")
  uploadedDesignFiles  TaskDesignFile[]     @relation("UploadedDesignFiles")
  taskFileLogs         TaskFileLog[]        @relation("TaskFileLogs")

  // 자재관리
  inventoryProcessed   InventoryTransaction[] @relation("InventoryProcessed")

  // 화상회의
  hostedMeetings        Meeting[]             @relation("HostedMeetings")
  meetingParticipants   MeetingParticipant[]  @relation("MeetingParticipants")
  meetingTranscripts    MeetingTranscript[]   @relation("MeetingTranscriptSpeakers")
  finalizedMinutes      MeetingMinutes[]      @relation("MeetingMinutesFinalizers")

  // 문서관리
  ownedFolders         DocumentFolder[]       @relation("OwnedFolders")
  uploadedDocuments    Document[]             @relation("UploadedDocuments")

  // 메일 (Phase 5)
  mailAccount          MailAccount?
  mailContacts         MailContact[]          @relation("MailContacts")
  mailAdminLogs        MailAdminLog[]         @relation("MailAdminLogs")

  // 알림 (v0.14.0)
  notifications        Notification[]          @relation("NotificationRecipient")
  sentNotifications    Notification[]          @relation("NotificationActor")

  // 초대 / 비밀번호 재설정 토큰 (v0.15.0)
  authTokens           AuthToken[]             @relation("UserAuthTokens")
  issuedAuthTokens     AuthToken[]             @relation("IssuedAuthTokens")

  // 캘린더 외부 동기화 (v0.16.0)
  calendarSubscriptions CalendarSubscription[] @relation("CalendarSubscriptions")

  // Google Calendar 양방향 동기화 (v0.18.0)
  calendarExternalSync CalendarExternalSync? @relation("CalendarExternalSyncs")

  @@index([departmentId])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Department {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  parentId  String? @map("parent_id")
  managerId String? @map("manager_id")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  depth     Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  manager  User?        @relation("DepartmentManager", fields: [managerId], references: [id])
  users    User[]

  @@index([parentId])
  @@index([code])
  @@map("departments")
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  deviceId   String   @map("device_id")
  deviceType String   @map("device_type") // web, ios, android
  deviceName String   @map("device_name")
  pushToken  String?  @map("push_token")
  isActive   Boolean  @default(true) @map("is_active")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("user_devices")
}

/// 사용자 초대 / 비밀번호 재설정 범용 토큰
/// - type=invite: 관리자가 가입 링크를 발송, 수신자가 비번 설정 후 계정 활성화
/// - type=password_reset: 본인이 요청, 새 비번 설정
/// - 만료 + 단일 사용 (usedAt 설정되면 재사용 불가)
enum AuthTokenType {
  invite
  password_reset
}

model AuthToken {
  id         String         @id @default(uuid())
  token      String         @unique                         // URL-safe random (32바이트)
  type       AuthTokenType
  email      String                                          // 수신자 이메일 (invite는 신규, reset은 기존)
  userId     String?        @map("user_id")                 // invite는 null (아직 user 없음), reset은 기존 user
  /// invite 시 관리자가 미리 지정한 메타 (employeeId, name, role, departmentId 등)
  invitePayload Json?       @map("invite_payload")
  createdById String        @map("created_by_id")           // 발급한 주체 (초대: 관리자, 재설정: 본인 or 시스템)
  expiresAt  DateTime       @map("expires_at")
  usedAt     DateTime?      @map("used_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  user      User?  @relation("UserAuthTokens", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User   @relation("IssuedAuthTokens", fields: [createdById], references: [id])

  @@index([token])
  @@index([email, type])
  @@index([userId])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_history")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  family    String   // Token family for rotation detection
  deviceId  String?  @map("device_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

// ===== 전자결재 =====

enum ApprovalDocStatus {
  draft
  pending
  approved
  rejected
  withdrawn
}

enum ApprovalLineStatus {
  pending
  approved
  rejected
  skipped
}

enum ApprovalLineType {
  serial
  parallel
}

model ApprovalTemplate {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  category    String  // 기안, 지출, 휴가, 출장, 구매, 보고, 회의록, 자유양식
  description String?
  formSchema  Json?   @map("form_schema") // 양식 필드 정의
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  documents ApprovalDocument[]

  @@map("approval_templates")
}

model ApprovalDocument {
  id             String            @id @default(uuid())
  docNumber      String            @unique @map("doc_number") // {양식코드}-{연도}-{순번}
  templateId     String            @map("template_id")
  title          String
  content        String            // HTML 본문
  formData       Json?             @map("form_data") // 양식 데이터
  status         ApprovalDocStatus @default(draft)
  drafterId      String            @map("drafter_id")
  currentStep    Int               @default(0) @map("current_step")
  urgency        String            @default("normal") // normal, urgent
  submittedAt    DateTime?         @map("submitted_at")
  completedAt    DateTime?         @map("completed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  template    ApprovalTemplate   @relation(fields: [templateId], references: [id])
  drafter     User               @relation("DraftedDocuments", fields: [drafterId], references: [id])
  lines       ApprovalLine[]
  attachments ApprovalAttachment[]
  references  ApprovalReference[]

  @@index([drafterId])
  @@index([status])
  @@index([templateId])
  @@index([createdAt])
  @@map("approval_documents")
}

model ApprovalLine {
  id         String             @id @default(uuid())
  documentId String             @map("document_id")
  approverId String             @map("approver_id")
  step       Int                // 결재 순서
  type       ApprovalLineType   @default(serial)
  status     ApprovalLineStatus @default(pending)
  comment    String?
  actedAt    DateTime?          @map("acted_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approver User             @relation("ApprovalLines", fields: [approverId], references: [id])

  @@index([documentId])
  @@index([approverId])
  @@index([status])
  @@map("approval_lines")
}

model ApprovalAttachment {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("approval_attachments")
}

model ApprovalReference {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User             @relation("ApprovalReferences", fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@index([userId])
  @@map("approval_references")
}

model ApprovalDelegation {
  id          String    @id @default(uuid())
  fromUserId  String    @map("from_user_id")
  toUserId    String    @map("to_user_id")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  reason      String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  fromUser User @relation("DelegationsFrom", fields: [fromUserId], references: [id])
  toUser   User @relation("DelegationsTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@map("approval_delegations")
}

// ===== 메신저 =====

enum MessageType {
  text
  image
  file
  system
}

model ChatRoom {
  id        String   @id @default(uuid())
  name      String?
  type      String   @default("direct") // direct, group
  creatorId String?  @map("creator_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator      User?             @relation("CreatedRooms", fields: [creatorId], references: [id], onDelete: SetNull)
  participants ChatParticipant[]
  messages     Message[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id            String    @id @default(uuid())
  roomId        String    @map("room_id")
  userId        String    @map("user_id")
  lastReadAt    DateTime  @default(now()) @map("last_read_at")
  isNotifyOn    Boolean   @default(true) @map("is_notify_on")
  joinedAt      DateTime  @default(now()) @map("joined_at")
  leftAt        DateTime? @map("left_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation("ChatParticipants", fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

/// 채팅 메시지
/// - v0.19.0: (roomId, createdAt desc) 인덱스 추가 (unread count + 최신 목록)
model Message {
  id        String      @id @default(uuid())
  roomId    String      @map("room_id")
  senderId  String?     @map("sender_id")
  type      MessageType @default(text)
  content   String
  metadata  Json?       // 파일정보, 이미지 사이즈 등
  parentId  String?     @map("parent_id") // 답장
  isEdited  Boolean     @default(false) @map("is_edited")
  isDeleted Boolean     @default(false) @map("is_deleted")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  room    ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender  User?        @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)
  parent  Message?     @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Message[]    @relation("MessageReplies")
  reads   MessageRead[]
  mentions MessageMention[]

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageReads", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model MessageMention {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageMentions", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_mentions")
}

// ===== CCTV =====

model Camera {
  id          String  @id @default(uuid())
  name        String
  rtspUrl     String  @map("rtsp_url")
  location    String?
  groupId     String? @map("group_id")
  isActive    Boolean @default(true) @map("is_active")
  isPtz       Boolean @default(false) @map("is_ptz")
  sortOrder   Int     @default(0) @map("sort_order")
  /// PTZ 어댑터 종류 (stub/onvif/hikvision/dahua 등)
  ptzAdapter  String? @map("ptz_adapter")
  ptzUsername String? @map("ptz_username")
  ptzPassword String? @map("ptz_password")           // AES-256-GCM 권장 (프로덕션)
  /// 공개 카메라 (누구나 볼 수 있음, 기본 false)
  isPublic    Boolean @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group       CameraGroup? @relation(fields: [groupId], references: [id])
  recordings  Recording[]
  permissions CameraPermission[]

  @@index([groupId])
  @@map("cameras")
}

/// 카메라 접근 권한 (CAM-007)
/// - subjectType별로 사용자/부서/role 단위 허용
/// - level: 'view' (실시간 시청 + 녹화 조회) / 'control' (+ PTZ 제어)
enum CameraPermissionSubjectType {
  user
  department
  role
}

enum CameraPermissionLevel {
  view
  control
}

model CameraPermission {
  id           String                      @id @default(uuid())
  cameraId     String                      @map("camera_id")
  subjectType  CameraPermissionSubjectType @map("subject_type")
  /// user id / department id / role name (UserRole의 string)
  subjectId    String                      @map("subject_id")
  level        CameraPermissionLevel       @default(view)
  createdAt    DateTime                    @default(now()) @map("created_at")

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@unique([cameraId, subjectType, subjectId])
  @@index([subjectType, subjectId])
  @@map("camera_permissions")
}

model CameraGroup {
  id        String   @id @default(uuid())
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  cameras Camera[]

  @@map("camera_groups")
}

model Recording {
  id        String   @id @default(uuid())
  cameraId  String   @map("camera_id")
  filePath  String   @map("file_path")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  fileSize  BigInt   @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId, startTime])
  @@map("recordings")
}

// ===== 근태관리 =====

enum AttendanceType {
  check_in
  check_out
}

enum VacationType {
  annual        // 연차
  half_am       // 오전 반차
  half_pm       // 오후 반차
  sick          // 병가
  special       // 특별휴가
  compensatory  // 대체휴가
}

enum VacationStatus {
  pending
  approved
  rejected
  cancelled
}

model Attendance {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  type         AttendanceType
  checkTime    DateTime       @map("check_time")
  latitude     Float?
  longitude    Float?
  ipAddress    String?        @map("ip_address")
  deviceType   String?        @map("device_type")
  note         String?
  createdAt    DateTime       @default(now()) @map("created_at")

  user User @relation("Attendances", fields: [userId], references: [id])

  @@index([userId, checkTime])
  @@map("attendances")
}

model WorkSchedule {
  id        String @id @default(uuid())
  name      String
  startTime String @map("start_time") // "09:00"
  endTime   String @map("end_time")   // "18:00"
  isDefault Boolean @default(false) @map("is_default")

  @@map("work_schedules")
}

model Vacation {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  type             VacationType
  startDate        DateTime       @map("start_date")
  endDate          DateTime       @map("end_date")
  days             Float          // 0.5 for half-day
  reason           String?
  status           VacationStatus @default(pending)
  approvalDocId    String?        @map("approval_doc_id")
  approvedBy       String?        @map("approved_by")
  approvedAt       DateTime?      @map("approved_at")
  rejectionReason  String?        @map("rejection_reason")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user User @relation("Vacations", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("vacations")
}

model VacationBalance {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  year        Int
  totalDays   Float  @default(15) @map("total_days")
  usedDays    Float  @default(0)  @map("used_days")
  remainDays  Float  @default(15) @map("remain_days")
  /// 해당 연도의 연차 산정 기준 (근로기준법: 근속1년 미만은 월차, 1년~3년은 15일, 이후 2년마다 +1)
  tenureYears Float? @map("tenure_years")
  grantedAt   DateTime? @map("granted_at")   // 자동 부여 시점
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation("VacationBalances", fields: [userId], references: [id])

  @@unique([userId, year])
  @@map("vacation_balances")
}

/// 공휴일 / 회사 휴무일 모델
/// - 근태·휴가 일수 계산 시 제외
/// - isCompanyHoliday=true 는 법정 공휴일 외에 회사가 지정한 휴무 (창립기념일, 단축근무 등)
enum HolidayType {
  legal           // 법정 공휴일 (설날, 추석 등)
  substitute      // 대체공휴일
  company         // 회사 지정 휴무
  event           // 기념일 (정상 근무 — 일수 계산엔 제외 X, 참고용)
}

model Holiday {
  id           String       @id @default(uuid())
  date         DateTime     @db.Date                          // 날짜 (하루 단위)
  name         String                                          // "설날", "창립기념일" 등
  type         HolidayType  @default(legal)
  /// 연차/주52시간 계산에서 제외 여부 (event 는 false, 나머지는 true 기본)
  excludeFromWorkdays Boolean @default(true) @map("exclude_from_workdays")
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([date, name])
  @@index([date])
  @@index([type])
  @@map("holidays")
}

// ===== 캘린더 =====

enum EventRepeat {
  none
  daily
  weekly
  monthly
  yearly
}

model CalendarEvent {
  id          String      @id @default(uuid())
  title       String
  description String?
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  allDay      Boolean     @default(false) @map("all_day")
  location    String?
  /// 카테고리 색상을 덮어쓰는 개별 색 (없으면 category.color 사용)
  color       String?     @default("#3b82f6")
  categoryId  String?     @map("category_id")
  repeat      EventRepeat @default(none)
  /// 반복 종료일 (null = 무제한 반복)
  repeatUntil DateTime?   @map("repeat_until")
  /// 반복 이벤트에서 제외된 날짜들 ("이 날짜만 삭제" 사용)
  /// YYYY-MM-DD 문자열 배열로 저장 (timezone 이슈 최소화)
  exceptionDates String[] @default([]) @map("exception_dates")
  scope       String      @default("personal") // personal, department, company
  creatorId   String      @map("creator_id")
  departmentId String?    @map("department_id")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  creator      User                       @relation("CalendarEvents", fields: [creatorId], references: [id])
  category     CalendarCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attendees    EventAttendee[]
  externalMaps CalendarEventExternalMap[] @relation("EventExternalMaps")

  @@index([creatorId])
  @@index([startDate, endDate])
  @@index([scope])
  @@index([categoryId])
  @@map("calendar_events")
}

/// 캘린더 카테고리 (색상 + 이름)
/// - ownerId가 null: 전역 기본 카테고리 (seed로 생성)
/// - ownerId가 not null: 해당 사용자가 추가로 만든 개인 카테고리
/// - color: 16진수 컬러 코드 (#RRGGBB)
/// - isDefault: 시스템 시드 카테고리 (삭제 방지)
model CalendarCategory {
  id        String   @id @default(uuid())
  name      String
  color     String                                  // #RRGGBB
  ownerId   String?  @map("owner_id")               // null = 전역 / not null = 개인
  isDefault Boolean  @default(false) @map("is_default")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner  User?           @relation("OwnedCalendarCategories", fields: [ownerId], references: [id], onDelete: Cascade)
  events CalendarEvent[]

  @@index([ownerId])
  @@map("calendar_categories")
}

model EventAttendee {
  id       String @id @default(uuid())
  eventId  String @map("event_id")
  userId   String @map("user_id")
  status   String @default("pending") // pending, accepted, declined

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("EventAttendees", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ===== 게시판 =====

model Board {
  id          String  @id @default(uuid())
  name        String  @unique
  type        String  @default("general") // notice, general, department
  description String?
  departmentId String? @map("department_id")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  posts Post[]

  @@map("boards")
}

model Post {
  id         String   @id @default(uuid())
  boardId    String   @map("board_id")
  authorId   String   @map("author_id")
  title      String
  content    String   // HTML
  isPinned   Boolean  @default(false) @map("is_pinned")
  isMustRead Boolean  @default(false) @map("is_must_read")
  viewCount  Int      @default(0) @map("view_count")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  board       Board         @relation(fields: [boardId], references: [id])
  author      User          @relation("AuthoredPosts", fields: [authorId], references: [id])
  comments    Comment[]
  reads       PostRead[]
  attachments PostAttachment[]

  @@index([boardId, createdAt])
  @@index([authorId])
  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User      @relation("AuthoredComments", fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
  @@map("comments")
}

model PostRead {
  id     String   @id @default(uuid())
  postId String   @map("post_id")
  userId String   @map("user_id")
  readAt DateTime @default(now()) @map("read_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReads", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_reads")
}

model PostAttachment {
  id       String   @id @default(uuid())
  postId   String   @map("post_id")
  fileName String   @map("file_name")
  filePath String   @map("file_path")
  fileSize Int      @map("file_size")
  mimeType String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

// ===== 작업지시서 =====

enum TaskOrderStatus {
  draft
  instructed
  in_progress
  partial_complete
  work_complete
  billing_complete
  final_complete
  discarded
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum BillingType {
  tax_invoice
  cash_receipt
  other
}

enum BillingStatus {
  pending
  billed
  paid
}

enum FileLogAction {
  upload
  download
  view
  approve
  reject
}

model Client {
  id              String  @id @default(uuid())
  companyName     String  @map("company_name")
  businessNumber  String? @map("business_number")
  representative  String?
  contactPerson   String? @map("contact_person")
  phone           String?
  email           String?
  address         String?
  note            String?
  isActive        Boolean @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  taskOrders     TaskOrder[]
  supplierItems  InventoryItem[] @relation("SupplierItems")

  @@map("clients")
}

model TaskOrder {
  id                  String          @id @default(uuid())
  taskNumber          String          @unique @map("task_number")
  title               String
  description         String?
  creatorId           String          @map("creator_id")
  priority            TaskPriority    @default(normal)
  status              TaskOrderStatus @default(draft)
  category            String?
  instructionDate     DateTime?       @map("instruction_date")
  dueDate             DateTime?       @map("due_date")
  completedAt         DateTime?       @map("completed_at")
  clientId            String?         @map("client_id")
  deliveryAddress     Json?           @map("delivery_address")
  additionalNote      String?         @map("additional_note")
  approvalDocumentId  String?         @map("approval_document_id")
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  creator       User                @relation("CreatedTaskOrders", fields: [creatorId], references: [id])
  client        Client?             @relation(fields: [clientId], references: [id])
  assignees     TaskAssignee[]
  items         TaskItem[]
  billing       TaskBilling?
  statusHistory TaskStatusHistory[]
  checklist     TaskChecklist[]
  comments      TaskComment[]
  designFiles   TaskDesignFile[]
  fileLogs      TaskFileLog[]

  @@index([creatorId])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@map("task_orders")
}

model TaskAssignee {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  userId String @map("user_id")
  role   String @default("main") // main, support, reviewer, designer
  status String @default("pending") // pending, accepted, completed

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskAssignees", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model TaskItem {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  itemName    String   @map("item_name")
  description String?
  quantity    Float    @default(1)
  unit        String?
  unitPrice   Float?   @map("unit_price")
  totalPrice  Float?   @map("total_price")
  sortOrder   Int      @default(0) @map("sort_order")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_items")
}

model TaskBilling {
  id               String        @id @default(uuid())
  taskId           String        @unique @map("task_id")
  billingRequired  Boolean       @default(true) @map("billing_required")
  billingType      BillingType?  @map("billing_type")
  amount           Float?
  vatIncluded      Boolean       @default(true) @map("vat_included")
  noBillingReason  String?       @map("no_billing_reason")
  billingStatus    BillingStatus @default(pending) @map("billing_status")
  billedAt         DateTime?     @map("billed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_billings")
}

model TaskStatusHistory {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String   @map("changed_by")
  comment    String?
  changedAt  DateTime @default(now()) @map("changed_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskStatusChanges", fields: [changedBy], references: [id])

  @@index([taskId])
  @@map("task_status_history")
}

model TaskChecklist {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  content     String
  isCompleted Boolean  @default(false) @map("is_completed")
  completedBy String?  @map("completed_by")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklists")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  task TaskOrder @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation("TaskComments", fields: [userId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model TaskDesignFile {
  id             String    @id @default(uuid())
  taskId         String    @map("task_id")
  fileName       String    @map("file_name")
  filePath       String    @map("file_path")
  fileSize       BigInt    @map("file_size")
  fileType       String    @map("file_type") // ai, psd, pdf, eps, svg
  mimeType       String    @map("mime_type")
  version        Int       @default(1)
  thumbnailPath  String?   @map("thumbnail_path")
  uploadedBy     String    @map("uploaded_by")
  isApproved     Boolean   @default(false) @map("is_approved")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  approveComment String?   @map("approve_comment")
  isLatest       Boolean   @default(true) @map("is_latest")
  parentFileId   String?   @map("parent_file_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  task       TaskOrder       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader   User            @relation("UploadedDesignFiles", fields: [uploadedBy], references: [id])
  parentFile TaskDesignFile?  @relation("DesignFileVersions", fields: [parentFileId], references: [id])
  versions   TaskDesignFile[] @relation("DesignFileVersions")
  logs       TaskFileLog[]

  @@index([taskId])
  @@index([uploadedBy])
  @@map("task_design_files")
}

model TaskFileLog {
  id          String        @id @default(uuid())
  taskId      String        @map("task_id")
  fileId      String        @map("file_id")
  userId      String        @map("user_id")
  action      FileLogAction
  ipAddress   String?       @map("ip_address")
  deviceType  String?       @map("device_type")
  deviceInfo  String?       @map("device_info")
  fileVersion Int           @map("file_version")
  comment     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  task TaskOrder      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file TaskDesignFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User           @relation("TaskFileLogs", fields: [userId], references: [id])

  @@index([taskId])
  @@index([fileId])
  @@index([userId])
  @@map("task_file_logs")
}

model DeliveryPreset {
  id            String  @id @default(uuid())
  name          String
  companyName   String? @map("company_name")
  contactPerson String? @map("contact_person")
  phone         String?
  address       String?
  isDefault     Boolean @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("delivery_presets")
}

// ===== 자재관리 =====

enum InventoryTxType {
  in_stock     // 입고
  out_stock    // 출고
  return_stock // 반품
  adjust       // 재고 조정
}

model InventoryCategory {
  id        String  @id @default(uuid())
  name      String
  parentId  String? @map("parent_id")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  parent   InventoryCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children InventoryCategory[] @relation("CategoryTree")
  items    InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id            String  @id @default(uuid())
  code          String  @unique // 자재코드
  name          String
  categoryId    String? @map("category_id")
  unit          String  @default("EA") // EA, BOX, SET, KG, M 등
  specification String? // 규격
  description   String?
  minStock      Int     @default(0) @map("min_stock")
  currentStock  Int     @default(0) @map("current_stock")
  unitPrice     Float?  @map("unit_price")
  location      String? // 보관위치
  supplierId    String? @map("supplier_id")
  imageUrl      String? @map("image_url")
  isActive      Boolean @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category     InventoryCategory? @relation(fields: [categoryId], references: [id])
  supplier     Client?            @relation("SupplierItems", fields: [supplierId], references: [id])
  transactions InventoryTransaction[]

  @@index([categoryId])
  @@index([code])
  @@map("inventory_items")
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  itemId      String          @map("item_id")
  type        InventoryTxType
  quantity    Int
  unitPrice   Float?          @map("unit_price")
  totalPrice  Float?          @map("total_price")
  beforeStock Int             @map("before_stock")
  afterStock  Int             @map("after_stock")
  reason      String?
  reference   String?         // 관련 문서번호 (작업지시서 등)
  processedBy String          @map("processed_by")
  processedAt DateTime        @default(now()) @map("processed_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  item      InventoryItem @relation(fields: [itemId], references: [id])
  processor User          @relation("InventoryProcessed", fields: [processedBy], references: [id])

  @@index([itemId])
  @@index([type])
  @@index([processedAt])
  @@map("inventory_transactions")
}

// ===== 화상회의 =====

enum MeetingStatus {
  scheduled
  in_progress
  ended
  cancelled
}

model Meeting {
  id           String        @id @default(uuid())
  title        String
  description  String?
  hostId       String        @map("host_id")
  status       MeetingStatus @default(scheduled)
  roomCode     String        @unique @map("room_code")
  scheduledAt  DateTime?     @map("scheduled_at")
  startedAt    DateTime?     @map("started_at")
  endedAt      DateTime?     @map("ended_at")
  maxParticipants Int        @default(16) @map("max_participants")
  isRecording  Boolean       @default(false) @map("is_recording")
  password     String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  host         User                @relation("HostedMeetings", fields: [hostId], references: [id])
  participants MeetingParticipant[]
  transcripts  MeetingTranscript[]
  minutes      MeetingMinutes?

  @@index([hostId])
  @@index([scheduledAt])
  @@index([status])
  @@map("meetings")
}

model MeetingParticipant {
  id        String    @id @default(uuid())
  meetingId String    @map("meeting_id")
  userId    String    @map("user_id")
  role      String    @default("participant") // host, participant
  joinedAt  DateTime? @map("joined_at")
  leftAt    DateTime? @map("left_at")
  isInvited Boolean   @default(true) @map("is_invited")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation("MeetingParticipants", fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

/// 회의 중 발언 기록 (실시간 STT 결과)
/// - 하나의 발언 = 하나의 row (isFinal=true만 저장)
/// - AI 요약 입력 소스
model MeetingTranscript {
  id          String   @id @default(uuid())
  meetingId   String   @map("meeting_id")
  speakerId   String?  @map("speaker_id")        // 매핑 안 될 수도 있음 (게스트 발언)
  speakerName String   @map("speaker_name")
  text        String   @db.Text
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker User?   @relation("MeetingTranscriptSpeakers", fields: [speakerId], references: [id], onDelete: SetNull)

  @@index([meetingId, timestamp])
  @@index([speakerId])
  @@map("meeting_transcripts")
}

enum MeetingMinutesStatus {
  generating   // Claude 요약 생성 중
  draft        // 생성 완료, 편집 가능
  final        // 확정 잠금
  failed       // 생성 실패
}

/// AI 자동 생성 회의록 (회의당 1개)
/// - status=generating → draft → final (편집 가능 → 잠금)
/// - summary: 전체 요약 (Markdown)
/// - decisions: 결정 사항 목록 (string[])
/// - actionItems: 액션 아이템 {assignee, task, dueDate?} 배열
/// - topics: 주요 논의 주제 목록 (string[])
model MeetingMinutes {
  id            String               @id @default(uuid())
  meetingId     String               @unique @map("meeting_id")
  status        MeetingMinutesStatus @default(generating)
  summary       String               @default("") @db.Text
  topics        String[]             @default([])
  decisions     String[]             @default([])
  actionItems   Json                 @default("[]") @map("action_items")   // [{assignee, task, dueDate?}]
  rawModelReply String?              @map("raw_model_reply") @db.Text      // 디버깅용 원본 응답
  errorMessage  String?              @map("error_message")
  generatedAt   DateTime?            @map("generated_at")
  finalizedAt   DateTime?            @map("finalized_at")
  finalizedById String?              @map("finalized_by_id")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  finalizedBy User?   @relation("MeetingMinutesFinalizers", fields: [finalizedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("meeting_minutes")
}

// ===== 문서관리 =====

model DocumentFolder {
  id        String  @id @default(uuid())
  name      String
  parentId  String? @map("parent_id")
  ownerId   String  @map("owner_id")
  isShared  Boolean @default(false) @map("is_shared")
  sortOrder Int     @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  owner     User             @relation("OwnedFolders", fields: [ownerId], references: [id])
  documents Document[]

  @@index([ownerId])
  @@index([parentId])
  @@map("document_folders")
}

model Document {
  id          String   @id @default(uuid())
  folderId    String?  @map("folder_id")
  uploaderId  String   @map("uploader_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    BigInt   @map("file_size")
  mimeType    String   @map("mime_type")
  version     Int      @default(1)
  description String?
  tags        String[] @default([])
  isShared    Boolean  @default(false) @map("is_shared")
  isActive    Boolean  @default(true) @map("is_active")
  downloadCount Int    @default(0) @map("download_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  folder   DocumentFolder?  @relation(fields: [folderId], references: [id])
  uploader User             @relation("UploadedDocuments", fields: [uploaderId], references: [id])
  versions DocumentVersion[]

  @@index([folderId])
  @@index([uploaderId])
  @@map("documents")
}

/// 문서 버전 이력 (VER-001~005)
/// - 현재 버전은 Document 자체에 저장, 이전 버전들을 DocumentVersion에 누적
/// - 파일 업데이트 시 기존 파일은 version N → DocumentVersion row로 복사, Document의 version +1
model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  version     Int                                          // 해당 버전 번호
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    BigInt   @map("file_size")
  mimeType    String   @map("mime_type")
  uploaderId  String   @map("uploader_id")
  changeNote  String?  @map("change_note")                 // 변경 사유/주석
  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId, createdAt(sort: Desc)])
  @@map("document_versions")
}

// ===== 관리콘솔 (SystemSetting) =====

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general") // general, security, notification, system
  description String?
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ===== 기능 모듈 관리 =====

model FeatureModule {
  id          String  @id @default(uuid())
  name        String  @unique
  displayName String  @map("display_name")
  description String?
  isEnabled   Boolean @default(true) @map("is_enabled")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_modules")
}

// ===== 감사 로그 =====

enum AuditAction {
  login
  logout
  login_failed
  token_refresh
  password_change
  user_create
  user_update
  user_delete
  role_change
  department_create
  department_update
  department_delete
  module_toggle
  settings_change
  approval_submit
  approval_approve
  approval_reject
  approval_withdraw
  approval_attachment_upload
  approval_attachment_delete
}

enum RiskLevel {
  low
  medium
  high
  critical
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String?     @map("user_id")
  action       AuditAction
  resourceType String?     @map("resource_type")
  resourceId   String?     @map("resource_id")
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  deviceId     String?     @map("device_id")
  details      Json?
  result       String      @default("success") // success, failure
  riskLevel    RiskLevel   @default(low) @map("risk_level")
  createdAt    DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([riskLevel])
  @@map("audit_logs")
}


// ===== 주차 추적 =====

enum ParkingEventType {
  entry
  exit
}

model ParkingZone {
  id         String   @id @default(uuid())
  name       String                         // e.g. "A구역"
  label      String                         // e.g. "A"
  x1         Float                          // normalized 0-1
  y1         Float
  x2         Float
  y2         Float
  totalSpots Int      @default(0) @map("total_spots")
  cameraId   String?  @map("camera_id")     // detection 서버 카메라 ID
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lines  ParkingLine[]
  events ParkingEvent[]

  @@map("parking_zones")
}

model ParkingLine {
  id        String   @id @default(uuid())
  zoneId    String   @map("zone_id")
  name      String                           // e.g. "입구 라인"
  type      String                           // "entry" | "exit" | "both"
  x1        Float                            // normalized 0-1
  y1        Float
  x2        Float
  y2        Float
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  zone ParkingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("parking_lines")
}

model ParkingEvent {
  id          String           @id @default(uuid())
  zoneId      String?          @map("zone_id")
  type        ParkingEventType
  plateNumber String?          @map("plate_number")  // 4자리
  trackId     Int?             @map("track_id")
  cameraId    String?          @map("camera_id")
  lineId      String?          @map("line_id")
  direction   String?                                  // "up", "down", "left", "right"
  createdAt   DateTime         @default(now()) @map("created_at")

  zone ParkingZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([type])
  @@index([plateNumber])
  @@index([zoneId])
  @@map("parking_events")
}

// ===== 메일 (Phase 5) =====

model MailDomain {
  id          String   @id @default(uuid())
  domain      String   @unique
  quotaBytes  BigInt   @default(107374182400) @map("quota_bytes")  // 100GB 기본
  maxAliases  Int      @default(400) @map("max_aliases")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("mail_domains")
}

/// 1인 1계정 원칙. WorkMail의 User와 1:1 매핑.
model MailAccount {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  email           String   @unique
  displayName     String   @map("display_name")

  /// WorkMail user ID (EntityId), 관리자 API 호출 시 사용
  workmailUserId  String?  @unique @map("workmail_user_id")

  imapHost        String   @default("imap.mail.us-east-1.awsapps.com") @map("imap_host")
  imapPort        Int      @default(993) @map("imap_port")
  smtpHost        String   @default("smtp.mail.us-east-1.awsapps.com") @map("smtp_host")
  smtpPort        Int      @default(465) @map("smtp_port")

  /// AES-256-GCM 암호화된 IMAP/SMTP 비밀번호 (iv:tag:ciphertext hex)
  encryptedPassword String @map("encrypted_password")

  quotaMB         Int      @default(51200) @map("quota_mb")      // 50GB
  usedMB          Float    @default(0) @map("used_mb")
  isActive        Boolean  @default(true) @map("is_active")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncError   String?  @map("last_sync_error")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        MailMessageCache[]

  @@map("mail_accounts")
}

/// IMAP 헤더 캐시. 본문은 캐시하지 않고 필요 시 IMAP에서 직접 FETCH.
model MailMessageCache {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  uid             BigInt                                    // IMAP UID (폴더 내 unique)
  folder          String   @default("INBOX")
  messageId       String   @map("message_id")               // RFC822 Message-ID
  subject         String?
  fromEmail       String   @map("from_email")
  fromName        String?  @map("from_name")
  toJson          Json     @map("to_json")                  // [{email, name}]
  ccJson          Json?    @map("cc_json")
  snippet         String?                                   // 본문 미리보기(~200자)
  sentAt          DateTime @map("sent_at")
  isSeen          Boolean  @default(false) @map("is_seen")
  isFlagged       Boolean  @default(false) @map("is_flagged")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  hasAttachment   Boolean  @default(false) @map("has_attachment")
  size            Int
  cachedAt        DateTime @default(now()) @map("cached_at")

  account         MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, folder, uid])
  @@index([accountId, folder, sentAt(sort: Desc)])
  @@index([accountId, messageId])
  @@map("mail_message_cache")
}

model MailContact {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  email       String
  name        String?
  frequency   Int      @default(1)                          // 자동완성 가중치
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation("MailContacts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId, frequency(sort: Desc)])
  @@map("mail_contacts")
}

model MailAdminLog {
  id          String   @id @default(uuid())
  actorId     String   @map("actor_id")
  targetEmail String   @map("target_email")
  action      String                                        // create, delete, quota, reset_password, activate, deactivate, link
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor       User     @relation("MailAdminLogs", fields: [actorId], references: [id])

  @@index([targetEmail, createdAt])
  @@index([actorId, createdAt])
  @@map("mail_admin_logs")
}

// ===== 캘린더 외부 동기화 (v0.16.0) =====

/// Google Calendar 등 외부 서비스와의 양방향 동기화 연동 (v0.18.0)
/// - provider별로 userId당 1개 (현재는 google만)
/// - OAuth2 토큰 AES-256-GCM 암호화 저장 (mailCrypto 재사용)
model CalendarExternalSync {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  provider           String                                          // "google"
  externalAccountId  String   @map("external_account_id")            // Google account email/sub
  externalCalendarId String   @default("primary") @map("external_calendar_id")
  accessTokenEnc     String   @map("access_token_enc")               // AES-256-GCM
  refreshTokenEnc    String   @map("refresh_token_enc")
  scope              String?                                         // granted scopes
  tokenExpiresAt     DateTime @map("token_expires_at")
  /// Google incremental sync token (events.list 호출에 사용)
  syncToken          String?  @map("sync_token")
  lastSyncedAt       DateTime? @map("last_synced_at")
  lastSyncError      String?  @map("last_sync_error")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation("CalendarExternalSyncs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@map("calendar_external_syncs")
}

/// 로컬 CalendarEvent ↔ 외부 이벤트 ID 매핑
/// - push/pull 시 중복 생성 방지 + 동기화 상태 추적
model CalendarEventExternalMap {
  id                 String   @id @default(uuid())
  eventId            String   @map("event_id")                       // 로컬 CalendarEvent.id
  provider           String                                          // "google"
  externalEventId    String   @map("external_event_id")
  externalCalendarId String   @map("external_calendar_id")
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at")
  createdAt          DateTime @default(now()) @map("created_at")

  event CalendarEvent @relation("EventExternalMaps", fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([provider, externalEventId])
  @@index([eventId, provider])
  @@map("calendar_event_external_maps")
}

/// 사용자별 ICS(iCalendar) 구독 URL
/// - 하나의 URL이 하나의 기기 또는 외부 캘린더에 대응
/// - token이 공개 feed 엔드포인트의 인증 역할 (랜덤 32바이트 URL-safe)
/// - reminderMinutes 배열로 VALARM 블록을 여러 개 생성 (N분 전)
model CalendarSubscription {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  token           String   @unique
  name            String                                          // "내 iPhone", "Google" 등 사용자 라벨
  /// 포함 범위: "personal" (본인 일정만) / "personal_dept" (+ 소속 부서) / "all" (전사)
  scope           String   @default("personal")
  includeVacation Boolean  @default(true) @map("include_vacation")
  includeMeeting  Boolean  @default(true) @map("include_meeting")
  includeTasks    Boolean  @default(false) @map("include_tasks")
  /// VALARM 트리거 시간 (분 전) — 복수 지정으로 여러 알림 가능
  reminderMinutes Int[]    @default([10]) @map("reminder_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  lastAccessedAt  DateTime? @map("last_accessed_at")
  accessCount     Int      @default(0) @map("access_count")
  /// 마지막 응답의 ETag (If-None-Match 304 지원)
  lastEtag        String?  @map("last_etag")
  createdAt       DateTime @default(now()) @map("created_at")
  revokedAt       DateTime? @map("revoked_at")

  user User @relation("CalendarSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([token])
  @@map("calendar_subscriptions")
}

// ===== 통합 알림 시스템 (v0.14.0) =====

enum NotificationType {
  // 결재
  approval_pending          // "결재할 문서가 도착했습니다"
  approval_approved         // "결재가 승인되었습니다"
  approval_rejected         // "결재가 반려되었습니다"
  approval_recalled         // "결재가 회수되었습니다"
  approval_reference        // "참조 문서가 도착했습니다"
  // 휴가
  vacation_approved         // "휴가가 승인되었습니다"
  vacation_rejected
  // 메신저
  message_received          // "새 메시지가 도착했습니다"
  message_mention           // "@멘션되었습니다"
  // 게시판
  post_must_read            // "필독 게시글이 등록되었습니다"
  // 작업지시서
  task_assigned             // "작업이 배정되었습니다"
  task_status_changed       // "작업 상태가 변경되었습니다"
  // 화상회의
  meeting_invited           // "회의에 초대되었습니다"
  meeting_starting_soon     // "예약된 회의가 5분 내 시작됩니다"
  meeting_minutes_ready     // "AI 회의록이 생성되었습니다"
  // 메일
  mail_received             // "새 메일이 도착했습니다"
  // 일반
  system                    // 시스템 알림
}

/// 통합 알림 — 모든 모듈에서 재사용
/// - recipientId: 알림 받는 사람
/// - actorId: 알림을 트리거한 사람 (nullable - 시스템 알림 등)
/// - type: NotificationType enum
/// - title/body: 화면 표시용 (다국어는 type 기반으로 클라이언트에서 재작성 가능)
/// - link: 클릭 시 이동 경로 (예: "/approval/documents/abc", "/meeting/xyz/minutes")
/// - refType/refId: 관련 리소스 (approval:xxx, meeting:xxx 등) — 조회/정리 용
/// - meta: 추가 정보 (Json, 자유롭게)
model Notification {
  id          String   @id @default(uuid())
  recipientId String   @map("recipient_id")
  actorId     String?  @map("actor_id")
  type        NotificationType
  title       String
  body        String?
  link        String?
  refType     String?  @map("ref_type")   // "approval" | "meeting" | "vacation" | "message" | ...
  refId       String?  @map("ref_id")
  meta        Json?
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([refType, refId])
  @@map("notifications")
}
