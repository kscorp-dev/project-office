{
  "expo": {
    "name": "Project Office",
    "slug": "project-office",
    "version": "0.21.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0fdf4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kscorp.projectoffice",
      "infoPlist": {
        "NSCameraUsageDescription": "화상회의 및 바코드 스캔에 카메라를 사용합니다.",
        "NSMicrophoneUsageDescription": "화상회의 음성 통화에 마이크를 사용합니다.",
        "NSLocationWhenInUseUsageDescription": "출퇴근 GPS 인증에 위치 정보를 사용합니다.",
        "NSFaceIDUsageDescription": "생체 인증 로그인에 Face ID를 사용합니다.",
        "NSContactsUsageDescription": "조직도/초대 시 연락처 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "첨부 사진 선택을 위해 사진 접근이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "촬영한 사진을 앨범에 저장합니다.",
        "NSCalendarsUsageDescription": "회사 일정을 휴대폰 캘린더에 추가합니다.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio",
          "voip",
          "remote-notification",
          "fetch"
        ]
      },
      "entitlements": {
        "aps-environment": "development"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.kscorp.projectoffice",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "USE_BIOMETRIC",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_PHONE_CALL",
        "POST_NOTIFICATIONS",
        "READ_PHONE_STATE",
        "CALL_PHONE",
        "MANAGE_OWN_CALLS",
        "BIND_TELECOM_CONNECTION_SERVICE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "화상회의에 카메라 접근이 필요합니다.",
          "microphonePermission": "화상회의 음성 통화에 마이크 접근이 필요합니다."
        }
      ],
      "@config-plugins/react-native-callkeep",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "사진 첨부를 위해 사진 라이브러리 접근이 필요합니다.",
          "cameraPermission": "현장 사진 촬영에 카메라 접근이 필요합니다."
        }
      ],
      "expo-document-picker",
      "./plugins/with-fmt-xcode26-fix.js",
      "./plugins/with-aps-environment.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "1.9.25",
            "extraProguardRules": "-keep class io.wazo.callkeep.** { *; }\n-keep class com.oney.WebRTCModule.** { *; }"
          }
        }
      ]
    ],
    "scheme": "projectoffice",
    "extra": {
      "apiUrl": "http://10.0.2.2:3000/api",
      "eas": {
        "projectId": "project-office"
      }
    },
    "owner": "kscorp"
  }
}
