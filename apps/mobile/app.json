{
  "expo": {
    "name": "Project Office",
    "slug": "project-office",
    "version": "0.12.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0fdf4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kscorp.projectoffice",
      "infoPlist": {
        "NSCameraUsageDescription": "화상회의 및 바코드 스캔에 카메라를 사용합니다.",
        "NSMicrophoneUsageDescription": "화상회의 음성 통화에 마이크를 사용합니다.",
        "NSLocationWhenInUseUsageDescription": "출퇴근 GPS 인증에 위치 정보를 사용합니다.",
        "NSFaceIDUsageDescription": "생체 인증 로그인에 Face ID를 사용합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.kscorp.projectoffice",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "USE_BIOMETRIC",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "화상회의에 카메라 접근이 필요합니다.",
          "microphonePermission": "화상회의 음성 통화에 마이크 접근이 필요합니다."
        }
      ]
    ],
    "scheme": "projectoffice",
    "extra": {
      "eas": {
        "projectId": "project-office"
      }
    },
    "owner": "kscorp"
  }
}
