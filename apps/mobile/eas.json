{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://43-200-29-148.sslip.io/api",
        "APP_ENV": "development",
        "EXPO_PUBLIC_APS_ENV": "development"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api",
        "APP_ENV": "development",
        "EXPO_PUBLIC_APS_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://43-200-29-148.sslip.io/api",
        "APP_ENV": "preview",
        "EXPO_PUBLIC_APS_ENV": "production"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://43-200-29-148.sslip.io/api",
        "APP_ENV": "production",
        "EXPO_PUBLIC_APS_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
