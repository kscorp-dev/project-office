# Staging 환경 변수 샘플 — 복사해서 .env.staging 으로 저장 후 수정
#
# $ cp .env.staging.example .env.staging
# $ vim .env.staging  # 프로덕션과 다른 값으로 채움
# $ ./scripts/staging.sh start

# ── Database (staging 전용 이름) ──
POSTGRES_DB=project_office_staging
POSTGRES_USER=po_staging
POSTGRES_PASSWORD=CHANGE_ME_staging_password_32_chars_or_more

# ── 포트 매핑 (프로덕션과 충돌 방지 위해 +10000) ──
PG_PORT=15433
REDIS_PORT=16380
BACKEND_PORT=13001
WEB_PORT=18080
DETECTION_PORT=18100

# ── Backend ──
# JWT: 프로덕션과 반드시 다른 값 사용
JWT_ACCESS_SECRET=CHANGE_ME_staging_jwt_access_secret_64_chars_random_string
JWT_REFRESH_SECRET=CHANGE_ME_staging_jwt_refresh_secret_64_chars_random_string

# Mail 암호화 키 (프로덕션과 달라도 됨, staging 전용)
MAIL_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_aes256_key_for_staging_only

# ── 도메인 ──
CORS_ORIGIN=http://localhost:18080
PUBLIC_BASE_URL=http://localhost:13001
WEB_URL=http://localhost:18080

# ── Web 빌드 ──
VITE_API_URL=http://localhost:13001/api

# ── 외부 서비스 — staging은 기본 비활성 ──
# 아래 항목은 선택적으로 staging에서도 테스트하려면 채움
# (안 채우면 자동 비활성 / 로그만)
ANTHROPIC_API_KEY=
SYSTEM_MAIL_SMTP_HOST=
SYSTEM_MAIL_USER=
SYSTEM_MAIL_PASS=

# Google OAuth (staging은 별도 Client ID 권장 — "승인된 리디렉션 URI"에 staging 도메인 등록)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:13001/api/calendar-sync/google/callback

# Expo push: 기본 비활성 (DISABLE_PUSH=true가 compose에서 설정됨)

# CCTV FFmpeg (staging에서 실영상 테스트 시에만)
CCTV_FFMPEG_PATH=

# AWS WorkMail (staging은 staging 전용 조직 권장 — 프로덕션 메일에 영향 X)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
WORKMAIL_ORG_ID=
